# Copy this file to .env for local real-target runs.
# Do not commit real provider keys.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.example.com/v1

LANGCHAIN_MODEL=openai:gpt-4.1-mini

# Required when using examples/target-contract-proposal-openai.py. This is
# intentionally separate from LANGCHAIN_MODEL so proposal-generation calls are
# always configured explicitly.
CONTRACT_PROPOSAL_MODEL=gpt-4.1-mini

# MAF reuses the generic OpenAI-compatible endpoint settings above unless you
# explicitly override them with COPILOT_PROVIDER_*.
COPILOT_PROVIDER_TYPE=openai
COPILOT_MODEL=gpt-4.1-mini

# Optional: MAF target wrapper settings.
# MAF_PYTHON=/abs/path/to/python
# MAF_COPILOT_CLI=copilot
# MAF_TIMEOUT=
# MAF_SESSION_HOME=
# MAF_LOG_LEVEL=
# MAF_WORKFLOW_PRE_TIMEOUT=2.0
# MAF_WORKFLOW_RESTORE_TIMEOUT=5.0
# MAF_WORKFLOW_EFFECT_SERVICE_URL=http://127.0.0.1:8910
