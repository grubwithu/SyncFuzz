# Copy this file to .env for local real-target runs.
# Do not commit real provider keys.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.example.com/v1

# Optional: keep the default model here instead of passing LANGCHAIN_MODEL to make.
LANGCHAIN_MODEL=openai:gpt-4.1-mini

# Optional: MAF target wrapper settings.
# SYNCFUZZ_MAF_PYTHON=/abs/path/to/python
# SYNCFUZZ_MAF_COPILOT_CLI=copilot
# SYNCFUZZ_MAF_MODEL=
# SYNCFUZZ_MAF_SESSION_HOME=
# SYNCFUZZ_MAF_LOG_LEVEL=
